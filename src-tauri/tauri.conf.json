{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mzansi Stream",
  "version": "1.0.0",
  "identifier": "za.mzansistream.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../public",
    "devUrl": "https://espg.vercel.app"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mzansi Stream — Premium IPTV South Africa",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "url": "https://espg.vercel.app/?source=tauri-windows",
        "userAgent": "MzansiStream/1.0 (Windows; Tauri)",
        "backgroundColor": "#000000",
        "theme": "Dark",
        "titleBarStyle": "Visible",
        "visible": true,
        "focus": true,
        "skipTaskbar": false,
        "shadow": true,
        "windowEffects": { "effects": ["acrylic"], "state": "active" }
      }
    ],
    "security": { "csp": null, "dangerousDisableAssetCspModification": false },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg"],
    "publisher": "Mzansi Stream",
    "homepage": "https://espg.vercel.app",
    "category": "Entertainment",
    "shortDescription": "Premium IPTV 4K — DStv alternative from R199/month",
    "longDescription": "Mzansi Stream is the official desktop app for the premium IPTV service for South Africa. 20,000+ live channels in 4K, live sport (DStv Premiership, URC, Premier League, F1, Cricket), movies and series. WhatsApp activation in 10 minutes. No contract.",
    "copyright": "© 2026 Mzansi Stream. All rights reserved.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [],
    "externalBin": [],
    "windows": {
      "wix": { "language": ["en-ZA", "en-US"] },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["English", "Afrikaans"],
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp"
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    },
    "linux": { "deb": { "depends": [] }, "appimage": { "bundleMediaFramework": true } },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "espg.vercel.app",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://espg.vercel.app/updates/{{target}}/{{current_version}}.json"],
      "dialog": true,
      "pubkey": "REPLACE_WITH_TAURI_PUBKEY_AFTER_GENERATING_KEYS"
    },
    "shell": { "open": true }
  }
}
