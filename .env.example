# ─── Mzansi Stream — public runtime config ─────────────────────────────────
# Fill these in your hosting provider (Vercel) before going live.
# All values are exposed to the browser, so put nothing secret here.

# Site
NEXT_PUBLIC_SITE_URL=https://iptvmzansi.com

# WhatsApp — country-specific numbers surfaced by the locale registry.
# `_DEFAULT` is the fallback used when no country-specific number is set.
# Format: digits only, country code first, no `+` (e.g. 27821234567).
NEXT_PUBLIC_WHATSAPP_DEFAULT=
NEXT_PUBLIC_WHATSAPP_ZA=
NEXT_PUBLIC_WHATSAPP_ZW=
NEXT_PUBLIC_WHATSAPP_BW=
NEXT_PUBLIC_WHATSAPP_NA=
NEXT_PUBLIC_WHATSAPP_MZ=
NEXT_PUBLIC_WHATSAPP_LS=
NEXT_PUBLIC_WHATSAPP_SZ=
NEXT_PUBLIC_WHATSAPP_ZM=
NEXT_PUBLIC_WHATSAPP_MW=
